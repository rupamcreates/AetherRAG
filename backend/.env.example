# Backend Environment Variables

# App Environment
ENV=development
DEBUG=true
PROJECT_NAME="Enterprise Multimodal RAG API"

# API Server
PORT=8000
HOST=0.0.0.0

# Database (Supabase PostgreSQL + pgvector)
# Local: postgresql://postgres:postgres@localhost:5432/rag_db
# Supabase: postgresql://postgres:[password]@db.[supabase-project-id].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag_db

# Task Queue (Upstash Redis)
# Local: redis://localhost:6379/0
# Upstash: rediss://default:[password]@[upstash-endpoint].upstash.io:6379
REDIS_URL=redis://localhost:6379/0

# Object Storage (Supabase Storage / Cloudflare R2 / AWS S3)
STORAGE_PROVIDER=supabase  # 'supabase' or 's3' or 'local'
STORAGE_BUCKET_NAME=documents
# Supabase Storage Config
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# S3 / Cloudflare R2 Config (if provider is s3)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_ENDPOINT_URL=https://your-cloudflare-account-id.r2.cloudflarestorage.com

# LLM Providers & Embeddings
GROQ_API_KEY=your-groq-api-key
HUGGINGFACE_API_KEY=your-huggingface-api-key

# Embedding Configuration
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384

# Unstructured Serverless API
UNSTRUCTURED_API_KEY=your-unstructured-api-key
UNSTRUCTURED_API_URL=https://api.unstructuredapp.io/general/v0/general

# Clerk Authentication (Shared with Frontend)
CLERK_API_URL=https://api.clerk.com/v1
CLERK_SECRET_KEY=your-clerk-secret-key
